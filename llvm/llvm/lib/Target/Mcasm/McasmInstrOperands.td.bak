// Pointer register class (32-bit only for mcasm)
def x86_ptr_rc : RegisterClass<"Mcasm", [i32], 32, (add GR32)>;

// Pointer register class excluding stack pointer
def ptr_rc_nosp : RegisterClass<"Mcasm", [i32], 32, (add GR32_NOSP)>;

// *mem - Operand definitions for the funky Mcasm addressing mode operands.
//
def McasmMemAsmOperand : AsmOperandClass {
 let Name = "Mem";
}
let RenderMethod = "addMemOperands", SuperClasses = [McasmMemAsmOperand] in {
  def McasmMem8AsmOperand   : AsmOperandClass { let Name = "Mem8"; }
  def McasmMem16AsmOperand  : AsmOperandClass { let Name = "Mem16"; }
  def McasmMem32AsmOperand  : AsmOperandClass { let Name = "Mem32"; }
  def McasmMem64AsmOperand  : AsmOperandClass { let Name = "Mem64"; }
  def McasmMem80AsmOperand  : AsmOperandClass { let Name = "Mem80"; }
  def McasmMem128AsmOperand : AsmOperandClass { let Name = "Mem128"; }
  def McasmMem256AsmOperand : AsmOperandClass { let Name = "Mem256"; }
  def McasmMem512AsmOperand : AsmOperandClass { let Name = "Mem512"; }
  // Gather mem operands
  def McasmMem32_RC128Operand  : AsmOperandClass { let Name = "Mem32_RC128"; }
  def McasmMem64_RC128Operand  : AsmOperandClass { let Name = "Mem64_RC128"; }
  def McasmMem32_RC256Operand  : AsmOperandClass { let Name = "Mem32_RC256"; }
  def McasmMem64_RC256Operand  : AsmOperandClass { let Name = "Mem64_RC256"; }

  def McasmMem32_RC128XOperand  : AsmOperandClass { let Name = "Mem32_RC128X"; }
  def McasmMem64_RC128XOperand  : AsmOperandClass { let Name = "Mem64_RC128X"; }
  def McasmMem32_RC256XOperand  : AsmOperandClass { let Name = "Mem32_RC256X"; }
  def McasmMem64_RC256XOperand  : AsmOperandClass { let Name = "Mem64_RC256X"; }
  def McasmMem32_RC512Operand   : AsmOperandClass { let Name = "Mem32_RC512"; }
  def McasmMem64_RC512Operand   : AsmOperandClass { let Name = "Mem64_RC512"; }

  def McasmMem512_GR16Operand : AsmOperandClass { let Name = "Mem512_GR16"; }
  def McasmMem512_GR32Operand : AsmOperandClass { let Name = "Mem512_GR32"; }
  def McasmMem512_GR64Operand : AsmOperandClass { let Name = "Mem512_GR64"; }

  def McasmSibMemOperand : AsmOperandClass { let Name = "SibMem"; }
}

def McasmAbsMemAsmOperand : AsmOperandClass {
  let Name = "AbsMem";
  let SuperClasses = [McasmMemAsmOperand];
}

class McasmMemOperand<string printMethod,
                    AsmOperandClass parserMatchClass = McasmMemAsmOperand,
                    int size = 0> : Operand<iPTR> {
  let PrintMethod = printMethod;
  let MIOperandInfo = (ops x86_ptr_rc, i8imm, ptr_rc_nosp, i32imm, SEGMENT_REG);
  let ParserMatchClass = parserMatchClass;
  let OperandType = "OPERAND_MEMORY";
  int Size = size;
}

// Gather mem operands
class McasmVMemOperand<RegisterClass RC, string printMethod,
                     AsmOperandClass parserMatchClass, int size = 0>
    : McasmMemOperand<printMethod, parserMatchClass, size> {
  let MIOperandInfo = (ops x86_ptr_rc, i8imm, RC, i32imm, SEGMENT_REG);
}

def anymem : McasmMemOperand<"printMemReference">;

// FIXME: Right now we allow any size during parsing, but we might want to
// restrict to only unsized memory.
def opaquemem : McasmMemOperand<"printMemReference">;

def sibmem: McasmMemOperand<"printMemReference", McasmSibMemOperand>;

def i8mem   : McasmMemOperand<"printbytemem",   McasmMem8AsmOperand, 8>;
def i16mem  : McasmMemOperand<"printwordmem",  McasmMem16AsmOperand, 16>;
def i32mem  : McasmMemOperand<"printdwordmem",  McasmMem32AsmOperand, 32>;
def i64mem  : McasmMemOperand<"printqwordmem",  McasmMem64AsmOperand, 64>;
def i128mem : McasmMemOperand<"printxmmwordmem", McasmMem128AsmOperand, 128>;
def i256mem : McasmMemOperand<"printymmwordmem", McasmMem256AsmOperand, 256>;
def i512mem : McasmMemOperand<"printzmmwordmem", McasmMem512AsmOperand, 512>;
def f16mem  : McasmMemOperand<"printwordmem",   McasmMem16AsmOperand, 16>;
def f32mem  : McasmMemOperand<"printdwordmem",  McasmMem32AsmOperand, 32>;
def f64mem  : McasmMemOperand<"printqwordmem",  McasmMem64AsmOperand, 64>;
def f80mem  : McasmMemOperand<"printtbytemem",  McasmMem80AsmOperand, 80>;
def f128mem : McasmMemOperand<"printxmmwordmem", McasmMem128AsmOperand, 128>;
def f256mem : McasmMemOperand<"printymmwordmem", McasmMem256AsmOperand, 256>;
def f512mem : McasmMemOperand<"printzmmwordmem", McasmMem512AsmOperand, 512>;

// 32/64 mode specific mem operands
def i512mem_GR16 : McasmMemOperand<"printzmmwordmem", McasmMem512_GR16Operand, 512>;
def i512mem_GR32 : McasmMemOperand<"printzmmwordmem", McasmMem512_GR32Operand, 512>;
def i512mem_GR64 : McasmMemOperand<"printzmmwordmem", McasmMem512_GR64Operand, 512>;

// Gather mem operands
def vx32mem  : McasmVMemOperand<VR128,  "printdwordmem",  McasmMem32_RC128Operand, 32>;
def vx64mem  : McasmVMemOperand<VR128,  "printqwordmem",  McasmMem64_RC128Operand, 64>;
def vy32mem  : McasmVMemOperand<VR256,  "printdwordmem",  McasmMem32_RC256Operand, 32>;
def vy64mem  : McasmVMemOperand<VR256,  "printqwordmem",  McasmMem64_RC256Operand, 64>;

def vx32xmem  : McasmVMemOperand<VR128X, "printdwordmem",  McasmMem32_RC128XOperand, 32>;
def vx64xmem  : McasmVMemOperand<VR128X, "printqwordmem",  McasmMem64_RC128XOperand, 64>;
def vy32xmem  : McasmVMemOperand<VR256X, "printdwordmem",  McasmMem32_RC256XOperand, 32>;
def vy64xmem  : McasmVMemOperand<VR256X, "printqwordmem",  McasmMem64_RC256XOperand, 64>;
def vz32mem   : McasmVMemOperand<VR512,  "printdwordmem",  McasmMem32_RC512Operand,  32>;
def vz64mem   : McasmVMemOperand<VR512,  "printqwordmem",  McasmMem64_RC512Operand,  64>;

def shmem : McasmMemOperand<"printwordmem", McasmMem16AsmOperand>;
def ssmem : McasmMemOperand<"printdwordmem", McasmMem32AsmOperand>;
def sdmem : McasmMemOperand<"printqwordmem", McasmMem64AsmOperand>;

// A version of i8mem for use on x86-64 and x32 that uses a NOREX GPR instead
// of a plain GPR, so that it doesn't potentially require a REX prefix.
def ptr_rc_norex : RegClassByHwMode<
  [Mcasm_32, Mcasm_64, Mcasm_64_X32],
  [GR32_NOREX, GR64_NOREX, GR32_NOREX]>;

def ptr_rc_norex_nosp : RegClassByHwMode<
  [Mcasm_32, Mcasm_64, Mcasm_64_X32],
  [GR32_NOREX_NOSP, GR64_NOREX_NOSP, GR32_NOREX_NOSP]>;


def i8mem_NOREX : McasmMemOperand<"printbytemem", McasmMem8AsmOperand, 8> {
  let MIOperandInfo = (ops ptr_rc_norex, i8imm, ptr_rc_norex_nosp, i32imm,
                       SEGMENT_REG);
}

// GPRs available for tailcall.
// It represents GR32_TC, GR64_TC or GR64_TCW64.
def ptr_rc_tailcall : RegClassByHwMode<
  [Mcasm_32, Mcasm_64, Mcasm_64_X32],
  [GR32_TC, GR64_TC, GR64_TC]>;

// Special i32mem for addresses of load folding tail calls. These are not
// allowed to use callee-saved registers since they must be scheduled
// after callee-saved register are popped.
def i32mem_TC : McasmMemOperand<"printdwordmem", McasmMem32AsmOperand, 32> {
  let MIOperandInfo = (ops ptr_rc_tailcall, i8imm, ptr_rc_tailcall,
                       i32imm, SEGMENT_REG);
}

// Special i64mem for addresses of load folding tail calls. These are not
// allowed to use callee-saved registers since they must be scheduled
// after callee-saved register are popped.
def i64mem_TC : McasmMemOperand<"printqwordmem", McasmMem64AsmOperand, 64> {
  let MIOperandInfo = (ops ptr_rc_tailcall, i8imm,
                       ptr_rc_tailcall, i32imm, SEGMENT_REG);
}

def i64mem_w64TC : McasmMemOperand<"printqwordmem", McasmMem64AsmOperand, 64> {
  let MIOperandInfo = (ops GR64_TCW64, i8imm,
                       GR64_TCW64, i32imm, SEGMENT_REG);
}

// Special parser to detect 16-bit mode to select 16-bit displacement.
def McasmAbsMemMode16AsmOperand : AsmOperandClass {
  let Name = "AbsMemMode16";
  let RenderMethod = "addAbsMemOperands";
  let SuperClasses = [McasmAbsMemAsmOperand];
}

def McasmAbsMem8AsmOperand : AsmOperandClass {
  let Name = "AbsMem8";
  let RenderMethod = "addAbsMemOperands";
  let SuperClasses = [McasmAbsMemAsmOperand];
}

// Branch targets print as pc-relative values.
class BranchTargetOperand<ValueType ty> : Operand<ty> {
  let OperandType = "OPERAND_PCREL";
  let PrintMethod = "printPCRelImm";
  let ParserMatchClass = McasmAbsMemAsmOperand;
}

def i32imm_brtarget : BranchTargetOperand<i32>;
def i16imm_brtarget : BranchTargetOperand<i16>;
def i8imm_brtarget : BranchTargetOperand<i8> {
  let ParserMatchClass = McasmAbsMem8AsmOperand;
}

// 64-bits but only 32 bits are significant, and those bits are treated as being
// pc relative.
def i64i32imm_brtarget : BranchTargetOperand<i64>;

def brtarget : BranchTargetOperand<OtherVT>;
def brtarget8 : BranchTargetOperand<OtherVT>;
def brtarget16 : BranchTargetOperand<OtherVT> {
  let ParserMatchClass = McasmAbsMemMode16AsmOperand;
}
def brtarget32 : BranchTargetOperand<OtherVT>;

